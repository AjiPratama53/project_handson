{
  "version": 2,
  "functions": {
    "api/fortune-edge.js": {
      "runtime": "edge",
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/public/collection/*.JPG",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=100, s-maxage=300, stale-while-revalidate"
        }
      ]
    },
    {
      "source": "/public/collection/*.MP4",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/public/collection/DSC00002.JPG",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=100, s-maxage=300, stale-while-revalidate"
        }
      ]
    },
    {
      "source": "/public/collection/MAH01535.MP4",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/fortune.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate"
        }
      ]
    }
  ]
}